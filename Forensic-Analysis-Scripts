
import sqlite3

def analyze_sms_database(db_file):
    conn = sqlite3.connect(db_file)
    cursor = conn.cursor()
    
    # استعلام لجلب آخر 5 رسائل
    cursor.execute("SELECT address, body, date FROM sms ORDER BY date DESC LIMIT 5")
    
    print("--- Digital Forensics Report: SMS Logs ---")
    for row in cursor.fetchall():
        print(f"From: {row[0]} | Content: {row[1]} | Timestamp: {row[2]}")
    
    conn.close()

